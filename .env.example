# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=build360_db

# JWT
JWT_SECRET=build360_super_secret_key_change_in_production
JWT_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# OTP (use Twilio or MSG91 in production)
OTP_EXPIRY_MINUTES=10
